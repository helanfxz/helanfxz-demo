# Copy this file to .env when you want to call real model services.
# Leave the disable flags as 1 for local offline preview.

ARK_API_KEY=
ARK_TEXT_ENDPOINT_ID=
ARK_VIDEO_ENDPOINT_ID=

# Optional text LLM backends. Keep these empty unless you want to use them.
# Priority in code: DeepSeek, Ark text endpoint, then OpenAI-compatible TEXT_LLM_*.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

TEXT_LLM_BASE_URL=
TEXT_LLM_MODEL=
TEXT_LLM_API_KEY=
TEXT_LLM_TIMEOUT=60

AIGC_DISABLE_LLM=1
AIGC_DISABLE_VIDEO_MODEL=1
AIGC_DISABLE_BACKGROUND_REMOVAL=1
AIGC_VERBOSE_LOG=0

HOST=127.0.0.1
PORT=8010
